{
	"$schema": "https://docs.renovatebot.com/renovate-global-schema.json",

	// self-hosted
	"onboarding": false,
	"requireConfig": "ignored",
	"platform": "github",
	"repositories": ["spotdemo4/niks3-action"],
	"allowedCommands": ["npm audit fix", "npm i", "npm run build"],

	// repository
	"extends": ["config:recommended"],
	"lockFileMaintenance": {
		"enabled": true,
		"automerge": true,
		"schedule": ["* * * * 0"], // sunday
		"skipInstalls": false,
		"postUpgradeTasks": {
			"commands": ["npm audit fix"]
		}
	},
	"nix": {
		"enabled": true
	},
	"customManagers": [
		{
			"customType": "regex",
			"managerFilePatterns": ["src/niks3.ts"],
			"matchStrings": [
				"const version = \"(?<currentValue>.*)\"; // github-tags/(?<depName>.*?)(\\&versioning=(?<versioning>.*?))?\\s"
			],
			"datasourceTemplate": "github-tags"
		}
	],
	"packageRules": [
		{
			"matchUpdateTypes": ["minor", "patch", "pin", "digest"],
			"automerge": true
		},
		{
			"matchManagers": ["npm"],
			"rangeStrategy": "bump",
			"postUpdateOptions": ["npmInstallTwice"]
		},
		{
			"matchManagers": ["npm"],
			"matchDepTypes": ["engines"],
			"enabled": false
		},
		{
			"matchManagers": ["npm"],
			"matchUpdateTypes": ["minor", "patch"],
			"groupName": "node packages"
		},
		{
			"matchManagers": ["nix"],
			"groupName": "nix inputs"
		},
		{
			"matchManagers": ["github-actions"],
			"groupName": "github actions"
		},
		{
			"matchManagers": ["npm", "custom.regex"],
			"postUpgradeTasks": {
				"commands": ["npm i", "npm run build"]
			}
		}
	]
}
